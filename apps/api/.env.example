# Configuración del Backend (FastAPI - Python)

# Base de Datos (PostgreSQL en Producción)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=corales_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Seguridad
SECRET_KEY=cambiar_por_una_cadena_larga_y_aleatoria
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # 7 días

# Entorno (development | production)
ENVIRONMENT=development

# Storage (local | s3)
STORAGE_MODE=local
S3_BUCKET=corales-assets
S3_ACCESS_KEY=tu_access_key
S3_SECRET_KEY=tu_secret_key
S3_ENDPOINT_URL=https://tu-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_PUBLIC_URL_OVERRIDE=https://pub-id.r2.dev

# CORS
FRONTEND_URL=http://localhost:3000
